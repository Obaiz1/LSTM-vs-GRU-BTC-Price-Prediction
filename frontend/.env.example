# Base URL of the FastAPI backend the dashboard talks to.
#
# Local dev (Vite proxies /api -> http://localhost:8000): leave UNSET.
# Local dev against a container on another port:
#   VITE_API_BASE=http://localhost:8010
# Production (Vercel): set this to your hosted API, e.g. a Hugging Face Space:
#   VITE_API_BASE=https://obaiz1-btc-forecasting-api.hf.space
VITE_API_BASE=
